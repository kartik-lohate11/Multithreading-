            infoPanel.setBackground(WHITE);
            infoPanel.setOpaque(false);
            
            JLabel idLabel = new JLabel(testId);
            idLabel.setFont(new Font("Segoe UI", Font.BOLD, 13));
            idLabel.setForeground(TEXT_DARK);
            
            JLabel nameLabel = new JLabel(testName);
            nameLabel.setFont(new Font("Segoe UI", Font.PLAIN, 11));
            nameLabel.setForeground(TEXT_LIGHT);
            
            infoPanel.add(idLabel);
            infoPanel.add(nameLabel);
            
            add(infoPanel, BorderLayout.WEST);
            
            // Status Panel
            JPanel statusPanel = new JPanel(new GridLayout(1, 3, 40, 0));
            statusPanel.setBackground(WHITE);
            statusPanel.setOpaque(false);
            
            // Status
            JPanel statusCol = new JPanel(new BorderLayout());
            statusCol.setBackground(WHITE);
            statusCol.setOpaque(false);
            
            JLabel statusHeaderLabel = new JLabel("Status");
            statusHeaderLabel.setFont(new Font("Segoe UI", Font.PLAIN, 9));
            statusHeaderLabel.setForeground(TEXT_LIGHT);
            
            statusLabel = new JLabel("PENDING");
            statusLabel.setFont(new Font("Segoe UI", Font.BOLD, 12));
            statusLabel.setForeground(WARNING_ORANGE);
            
            statusCol.add(statusHeaderLabel, BorderLayout.NORTH);
            statusCol.add(statusLabel, BorderLayout.CENTER);
            statusPanel.add(statusCol);
            
            // Duration
            JPanel durationCol = new JPanel(new BorderLayout());
            durationCol.setBackground(WHITE);
            durationCol.setOpaque(false);
            
            JLabel durationHeaderLabel = new JLabel("Duration");
            durationHeaderLabel.setFont(new Font("Segoe UI", Font.PLAIN, 9));
            durationHeaderLabel.setForeground(TEXT_LIGHT);
            
            durationLabel = new JLabel("--");
            durationLabel.setFont(new Font("Segoe UI", Font.BOLD, 12));
            durationLabel.setForeground(TEXT_DARK);
            
            durationCol.add(durationHeaderLabel, BorderLayout.NORTH);
            durationCol.add(durationLabel, BorderLayout.CENTER);
            statusPanel.add(durationCol);
            
            // Result
            JPanel resultCol = new JPanel(new BorderLayout());
            resultCol.setBackground(WHITE);
            resultCol.setOpaque(false);
            
            JLabel resultHeaderLabel = new JLabel("Result");
            resultHeaderLabel.setFont(new Font("Segoe UI", Font.PLAIN, 9));
            resultHeaderLabel.setForeground(TEXT_LIGHT);
            
            resultLabel = new JLabel("--");
            resultLabel.setFont(new Font("Segoe UI", Font.BOLD, 12));
            resultLabel.setForeground(TEXT_DARK);
            
            resultCol.add(resultHeaderLabel, BorderLayout.NORTH);
            resultCol.add(resultLabel, BorderLayout.CENTER);
            statusPanel.add(resultCol);
            
            add(statusPanel, BorderLayout.CENTER);
            
            // Buttons
            JPanel buttonPanel = new JPanel(new FlowLayout(FlowLayout.RIGHT, 8, 0));
            buttonPanel.setBackground(WHITE);
            buttonPanel.setOpaque(false);
            
            JButton runBtn = createModernButton("RUN", PRIMARY_TEAL);
            runBtn.addActionListener(e -> runTest());
            
            JButton summaryBtn = createModernButton("SUMMARY", new Color(100, 150, 200));
            summaryBtn.addActionListener(e -> showSummary());
            
            buttonPanel.add(runBtn);
            buttonPanel.add(summaryBtn);
            
            add(buttonPanel, BorderLayout.EAST);
            
            // Mouse listener for hover
            addMouseListener(new MouseAdapter() {
                @Override
                public void mouseEntered(MouseEvent e) {
                    hovered = true;
                    startHoverAnimation();
                }
                
                @Override
                public void mouseExited(MouseEvent e) {
                    hovered = false;
                    stopHoverAnimation();
                }
            });
        }
        
        @Override
        protected void paintComponent(Graphics g) {
            Graphics2D g2d = (Graphics2D) g;
            g2d.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
            
            // Card background
            g2d.setColor(WHITE);
            g2d.fillRoundRect(0, 0, getWidth() - 1, getHeight() - 1, 10, 10);
            
            // Hover effect - lift shadow
            if (hoverAlpha > 0) {
                g2d.setColor(new Color(0, 0, 0, (int)(15 * hoverAlpha)));
                g2d.fillRoundRect(2, 3, getWidth() - 5, getHeight() - 2, 10, 10);
            }
            
            // Border
            g2d.setColor(BORDER_COLOR);
            g2d.setStroke(new BasicStroke(1));
            g2d.drawRoundRect(0, 0, getWidth() - 1, getHeight() - 1, 10, 10);
            
            super.paintComponent(g);
        }
        
        private void startHoverAnimation() {
            if (hoverTimer == null) {
                hoverTimer = new Timer(30, e -> {
                    hoverAlpha += 0.15f;
                    if (hoverAlpha > 1) {
                        hoverAlpha = 1;
                    }
                    repaint();
                });
                hoverTimer.start();
            }
        }
        
        private void stopHoverAnimation() {
            if (hoverTimer != null) {
                hoverTimer.stop();
                hoverTimer = null;
            }
            
            Timer fadeOut = new Timer(30, e -> {
                hoverAlpha -= 0.15f;
                if (hoverAlpha <= 0) {
                    hoverAlpha = 0;
                }
                repaint();
            });
            fadeOut.start();
        }
        
        private void runTest() {
            if (parent.isTestRunning) {
                JOptionPane.showMessageDialog(parent, 
                    "A test is already running. Please wait.", 
                    "Test In Progress", JOptionPane.INFORMATION_MESSAGE);
                return;
            }
            
            parent.isTestRunning = true;
            parent.currentRunningTest = index;
            
            statusLabel.setText("RUNNING");
            statusLabel.setForeground(WARNING_ORANGE);
            
            SwingWorker<Void, Integer> worker = new SwingWorker<Void, Integer>() {
                private long duration;
                private boolean passed;
                
                @Override
                protected Void doInBackground() throws Exception {
                    long startTime = System.currentTimeMillis();
                    duration = 800 + new Random().nextInt(2000);
                    
                    Thread.sleep(duration);
                    
                    passed = new Random().nextDouble() > 0.15;
                    
                    long endTime = System.currentTimeMillis();
                    duration = endTime - startTime;
                    
                    return null;
                }
                
                @Override
                protected void done() {
                    if (passed) {
                        statusLabel.setText("PASSED");
                        statusLabel.setForeground(SUCCESS_GREEN);
                        resultLabel.setText("PASS");
                        resultLabel.setForeground(SUCCESS_GREEN);
                    } else {
                        statusLabel.setText("FAILED");
                        statusLabel.setForeground(ERROR_RED);
                        resultLabel.setText("FAIL");
                        resultLabel.setForeground(ERROR_RED);
                    }
                    
                    durationLabel.setText(duration + "ms");
                    durationLabel.setForeground(TEXT_DARK);
                    
                    parent.isTestRunning = false;
                }
            };
            
            worker.execute();
        }
        
        private void showSummary() {
            if ("PENDING".equals(statusLabel.getText())) {
                JOptionPane.showMessageDialog(parent, 
                    "Test has not been executed yet. Click RUN to start.", 
                    "Test Not Executed", JOptionPane.INFORMATION_MESSAGE);
                return;
            }
            
            String message = String.format(
                "Test ID: %s\n\n" +
                "Test Name: %s\n\n" +
                "Status: %s\n" +
                "Duration: %s\n" +
                "Result: %s\n\n" +
                "Execution Time: %s",
                testId, testName, statusLabel.getText(), 
                durationLabel.getText(), resultLabel.getText(),
                new SimpleDateFormat("yyyy-MM-dd HH:mm:ss").format(new Date())
            );
            
            JOptionPane.showMessageDialog(parent, message, 
                "Test Summary - " + testId, JOptionPane.INFORMATION_MESSAGE);
        }
    }
    
    private JButton createModernButton(String text, Color bgColor) {
        JButton btn = new JButton(text) {
