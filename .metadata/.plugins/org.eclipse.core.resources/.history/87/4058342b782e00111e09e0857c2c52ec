import java.util.stream.Collectors;

public class Main {

	private static boolean primeNumber(Integer num) {
		if (num > 0 && num < 3)
			return true;
		for (int i = 2; i <= num / 2; i++) {
			if (num % i == 0) {
				return false;
			}
		}
		return true;
	}

	public static void main(String[] agr) {
		System.out.print(
		primeNumber(3));
	}

}
