	private static boolean primeNumber(Integer num) {
		if (num > 0 && num < 3)
			return true;
		for (int i = 2; i * i <= num; i++) {
			if (num % i == 0) {
				return false;
			}
		}
		return true;
	}

	private static Integer reverseInteger(Integer num) {
		Integer ans = 0;
		while (num != 0) {
			ans = ans * 10 + num % 10;
			num /= 10;
		}
		return ans;
	}

	private static void moveZero() {
		List<Integer> list = Arrays.asList(1, 2, 0, 3, 0, 2, 4, 6, 0, 3);
		Integer idx = 0;
		for (int i = 0; i < list.size(); i++) {
			if (list.get(i) != 0) {
				list.set(idx++, list.get(i));
			}
		}

		while (idx < list.size()) {
			list.set(idx++, 0);
		}

		System.out.print(list);
	}

	private static boolean anagram() {
		String a = "abcd";
		String b = "abcd";
		Integer tem[] = new Integer[26];

		for (int i = 0; i < a.length(); i++) {
			int idx = Math.abs(a.charAt(i) - 'a') % 26;
			if (tem[idx] == null) {
				tem[idx] = 1;
			} else {
				tem[idx]++;
			}
		}

		System.out.println(tem);

		for (int i = 0; i < b.length(); i++) {
			int idx = Math.abs(b.charAt(i) - 'a') % 26;
			if (tem[idx] != null) {
				tem[idx]--;
			}
		}
		System.out.println(tem);

		for (int i = 0; i < tem.length; i++) {
			if (tem[i] != null && tem[i] != 0) {
				return false;
			}
		}

		return true;

	}

	public static void main(String[] agr) {

		System.out.print(anagram());
	}

