public class Main {

	private static boolean primeNumber(Integer num) {
		if (num > 0 && num < 3)
			return true;
		for (int i = 2; i * i <= num; i++) {
			if (num % i == 0) {
				return false;
			}
		}
		return true;
	}

	private static Integer reverseInteger(Integer num) {
		boolean nav = num < 0 ? true : false;
		Integer ans = 0;
		while (num != 0) {
			ans = ans * 10 + num % 10;
			num /= 10;
		}
		if (nav==true)
			ans *= -1;
		return ans;
	}

	public static void main(String[] agr) {
		System.out.print(reverseInteger(100));
	}

}
